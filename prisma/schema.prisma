datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DEVELOPER
  TECHNIC
  REPORTER
  KRU
  MUSIC
}

enum PublishStatus {
  draft
  published
}

model ParticipantProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  displayName String?
  biodata     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions EventSubmission[]

  @@unique([userId])
}

model ProfileFieldCatalog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  label       String
  description String?
  fieldType   String
  isRequired  Boolean  @default(false)
  options     Json?
  metadata    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  slug        String        @unique
  title       String
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  status      PublishStatus @default(draft)
  createdById String        @db.ObjectId
  createdBy   User          @relation(fields: [createdById], references: [id])
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  organizers   EventOrganizer[]
  formVersions EventFormVersion[]
  submissions  EventSubmission[]
  exportLogs   EventExportLog[]
}

model EventOrganizer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  role      String?
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model EventFormVersion {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  eventId        String        @db.ObjectId
  event          Event         @relation(fields: [eventId], references: [id])
  version        Int
  status         PublishStatus @default(draft)
  title          String?
  formSchema     Json
  consentText    String
  consentVersion String
  publishedAt    DateTime?
  createdById    String?       @db.ObjectId
  createdBy      User?         @relation(fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  submissions EventSubmission[]

  @@unique([eventId, version])
}

model EventSubmission {
  id                       String              @id @default(auto()) @map("_id") @db.ObjectId
  eventId                  String              @db.ObjectId
  event                    Event               @relation(fields: [eventId], references: [id])
  formVersionId            String              @db.ObjectId
  formVersion              EventFormVersion    @relation(fields: [formVersionId], references: [id])
  participantProfileId     String?             @db.ObjectId
  participantProfile       ParticipantProfile? @relation(fields: [participantProfileId], references: [id])
  submitterUserId          String?             @db.ObjectId
  submitterUser            User?               @relation(fields: [submitterUserId], references: [id])
  respondentEmail          String?
  status                   String?
  answers                  Json
  formSchemaSnapshot       Json
  consentedProfileSnapshot Json
  consentTextSnapshot      String
  consentVersion           String
  submittedAt              DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([eventId, submittedAt])
  @@index([eventId, respondentEmail, submittedAt])
}

model EventExportLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId       String   @db.ObjectId
  event         Event    @relation(fields: [eventId], references: [id])
  requestedById String   @db.ObjectId
  requestedBy   User     @relation(fields: [requestedById], references: [id])
  exportType    String
  filters       Json?
  rowCount      Int?
  fileUrl       String?
  createdAt     DateTime @default(now())
}

model User {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  role               String              @default("KRU")
  createdAt          DateTime            @default(now())
  authored           AuthorOnPost[]
  accounts           Account[]
  sessions           Session[]
  shortLinks         ShortLink[]
  podcasts           Podcast[]
  participantProfile ParticipantProfile?
  events             Event[]
  eventOrganizers    EventOrganizer[]
  eventFormVersions  EventFormVersion[]
  eventSubmissions   EventSubmission[]
  eventExportLogs    EventExportLog[]
}

model BlogPost {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String         @unique
  content     String
  description String?
  readTime    String?
  category    String?
  mainImage   String?
  tags        String[]
  isFeatured  Boolean        @default(false)
  authors     AuthorOnPost[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model AuthorOnPost {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  user   User     @relation(fields: [userId], references: [id])
  userId String   @db.ObjectId
  post   BlogPost @relation(fields: [postId], references: [id])
  postId String   @db.ObjectId
}

model ShortLink {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  destination String
  slug        String           @unique
  title       String?
  domain      String           @default("8eh.link")
  password    String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String           @db.ObjectId
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks      ShortLinkClick[]
}

model ShortLinkClick {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  shortLinkId String    @db.ObjectId
  shortLink   ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  referer     String?
  country     String?
  city        String?
  clickedAt   DateTime  @default(now())
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?    @db.Int
  token_type        String? @db.String
  scope             String? @db.String
  id_token          String? @db.String
  session_state     String? @db.String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@index([identifier], map: "token_identifier_index")
}

model WhitelistedEmail {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}

model Podcast {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subtitle    String?
  description String
  date        String?
  duration    String?
  audioUrl    String
  image       String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
}

model PlayerConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subtitle    String?
  coverImage  String?
  coverImages String[] // semua cover image yang pernah diupload
  updatedAt   DateTime @updatedAt
}

model StreamConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  baseUrls    String[]
  defaultUrl  String
  fallbackUrl String
  onAir       Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model TuneTrackerEntry {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  order      Int // 1-10, chart position
  title      String
  artist     String
  coverImage String? // R2 URL
  audioUrl   String? // R2 URL
  updatedAt  DateTime @updatedAt
}

model ProgramVideo {
  id           String   @id @default(cuid()) @map("_id")
  title        String
  link         String
  thumbnail    String
  thumbnailKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
